# ========================================
# PROJECT-SPECULA: Environment Configuration
# ========================================
# Copy this to .env and customize settings

# === CAMERA CONFIGURATION ===
# 0 = Default webcam
# 1, 2, etc = Multiple cameras
# rtsp://user:pass@ip:port/stream = IP camera
CAMERA_SOURCE=0

# Threat detection threshold (0.0 - 1.0)
# Lower = More alerts, Higher = Fewer alerts
THREAT_THRESHOLD=0.55

# === PPE DETECTION ===
# Enable/disable PPE detection
ENABLE_PPE_DETECTION=True

# Use advanced models from Kaggle/Hugging Face
ENABLE_ADVANCED_MODELS=True

# Download models from Hugging Face (recommended)
USE_HUGGINGFACE_MODELS=True

# Download models from Kaggle (requires API token)
USE_KAGGLE_MODELS=False

# Required PPE items (comma-separated)
# Examples: helmet,safety_vest
# Options: helmet, hard_hat, safety_vest, vest, gloves, goggles, mask, boots, harness, etc.
REQUIRED_PPE=helmet,safety_vest

# PPE alert cooldown (seconds between alerts)
PPE_ALERT_COOLDOWN=60

# === DATABASE ===
# SQLite database file path
DATABASE_PATH=smart_cctv.db

# === ALERTS: SMS (Optional - leave blank to disable) ===
# Get Twilio credentials at: https://www.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1234567890
ALERT_SMS_TO=+0987654321

# === ALERTS: EMAIL (Optional - leave blank to disable) ===
# For Gmail: Use "App Password" (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_EMAIL_TO=alert@example.com

# === DEBUG ===
# development = Debug mode with auto-reload
# production = Optimized mode
FLASK_ENV=development

# Enable/disable Flask debug logging
DEBUG=False

# ========================================
# NOTES:
# ========================================
# 1. Save this file as .env in the project root
# 2. Edit values for your setup
# 3. Leave alert fields blank to disable
# 4. Restart app after changing values
#
# CAMERA EXAMPLES:
#   - Local webcam: 0
#   - USB camera: 1
#   - Hikvision: rtsp://user:pass@192.168.1.100:554/stream
#   - Dahua: rtsp://user:pass@192.168.1.100:554/stream
#   - Generic RTSP: rtsp://ip:port/path
#
# PPE EXAMPLES:
#   - Construction: helmet,safety_vest
#   - Factory: helmet,gloves,safety_vest
#   - Chemical: helmet,vest,gloves,goggles,respirator,boots
#
# ========================================
